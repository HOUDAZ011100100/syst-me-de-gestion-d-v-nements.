{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "composer install --no-dev --prefer-dist --no-interaction --no-progress --optimize-autoloader --ignore-platform-req=ext-mongodb",
  "buildCommand": "echo 'Skipping Vite build for backend API'",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php?__path=$1"
    }
  ]
}
