APP_NAME=VELORA
APP_ENV=production
APP_KEY=base64:generate-this-locally
APP_DEBUG=false
APP_URL=https://your-vercel-backend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mongodb
DB_DSN=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_DATABASE=velora

SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=array
FILESYSTEM_DISK=local
IMAGE_STORAGE_DRIVER=inline

RUN_MIGRATIONS=0
SEED_DEMO_DATA=0
